{
  "form_with model": {
    "prefix": "formwith",
    "description": "form_with model",
    "body": [
      "<%= form_with model: ${1:@resource}${2:, local: true} do |f| %>",
      "\t$0",
      "\t<div class=\"field\">",
      "\t\t<%= f.label :${3:name} %>",
      "\t\t<%= f.text_field :${3} %>",
      "\t</div>",
      "\t<%= f.submit %>",
      "<% end %>"
    ]
  },
  "form_with url": {
    "prefix": "formwithurl",
    "description": "form_with url",
    "body": [
      "<%= form_with url: ${1:path}, method: :${2:post} do |f| %>",
      "\t$0",
      "<% end %>"
    ]
  },
  "form field": {
    "prefix": "ffield",
    "description": "form field row",
    "body": [
      "<div class=\"field\">",
      "\t<%= f.label :${1:name} %>",
      "\t<%= f.${2:text_field} :${1} %>",
      "</div>$0"
    ]
  },
  "Form submit": {
    "prefix": "fsubmit",
    "description": "form submit",
    "body": ["<%= f.submit ${1:'Save'} %>$0"]
  },
  "render partial": {
    "prefix": "renderpartial",
    "description": "render partial",
    "body": ["<%= render '${1:partial}'${2:, ${3:item}: @${3}} %>$0"]
  },
  "render collection": {
    "prefix": "rendercollection",
    "description": "render collection",
    "body": ["<%= render partial: '${1:item}', collection: ${2:@items} %>$0"]
  },
  "link_to path": {
    "prefix": "linkto",
    "description": "link_to text path",
    "body": ["<%= link_to '${1:Label}', ${2:path} %>$0"]
  },
  "link_to method delete": {
    "prefix": "linkdelete",
    "description": "link_to delete data-confirm",
    "body": [
      "<%= link_to '${1:Delete}', ${2:path}, data: { turbo_method: :delete, turbo_confirm: '${3:Sure?}' } %>$0"
    ]
  },
  "button_to": {
    "prefix": "buttonto",
    "description": "button_to with method",
    "body": ["<%= button_to '${1:Label}', ${2:path}, method: :${3:post} %>$0"]
  },
  "image_tag": {
    "prefix": "imagetag",
    "description": "image_tag",
    "body": ["<%= image_tag '${1:img.png}' %>$0"]
  },
  "asset_path": {
    "prefix": "assetpath",
    "description": "asset_path",
    "body": ["<%= asset_path('${1:file}') %>$0"]
  },
  "content_for": {
    "prefix": "contentfor",
    "description": "content_for block",
    "body": [
      "<% content_for :${1:title} do %>",
      "\t$0",
      "<% end %>"
    ]
  },
  "yield": {
    "prefix": "yieldblock",
    "description": "yield block",
    "body": ["<%= yield ${1::title} %>$0"]
  },
  "flash messages": {
    "prefix": "flasheach",
    "description": "flash each",
    "body": [
      "<% flash.each do |type, msg| %>",
      "\t<div class=\"flash flash-<%= type %>\"><%= msg %></div>",
      "<% end %>$0"
    ]
  },
  "csrf meta": {
    "prefix": "csrfmeta",
    "description": "csrf meta + csp",
    "body": ["<%= csrf_meta_tags %>", "<%= csp_meta_tag %>$0"]
  },
  "Devise links": {
    "prefix": "deviselinks",
    "description": "Devise sign in/out links",
    "body": [
      "<% if user_signed_in? %>",
      "\t<%= link_to 'Sign out', destroy_user_session_path, data: { turbo_method: :delete } %>",
      "<% else %>",
      "\t<%= link_to 'Sign in', new_user_session_path %>",
      "\t<%= link_to 'Sign up', new_user_registration_path %>",
      "<% end %>$0"
    ]
  },
  "CanCanCan can?": {
    "prefix": "canqif",
    "description": "ERB can? guard",
    "body": [
      "<% if can? :${1:action}, ${2:resource} %>",
      "\t$0",
      "<% end %>"
    ]
  },
  "Turbo frame": {
    "prefix": "turboframe",
    "description": "turbo_frame_tag",
    "body": [
      "<%= turbo_frame_tag '${1:id}'${2:, src: ${3:path}} do %>",
      "\t$0",
      "<% end %>"
    ]
  },
  "Turbo frame lazy": {
    "prefix": "turboframelazy",
    "description": "turbo_frame_tag lazy load",
    "body": [
      "<%= turbo_frame_tag '${1:id}', src: ${2:path}, loading: :lazy %>$0"
    ]
  },
  "Turbo stream from": {
    "prefix": "turbostreamfrom",
    "description": "turbo_stream_from",
    "body": ["<%= turbo_stream_from ${1::room} %>$0"]
  },
  "Turbo stream replace": {
    "prefix": "turboreplace",
    "description": "turbo_stream replace partial",
    "body": [
      "<%= turbo_stream.replace '${1:dom_id}', partial: '${2:partial}', locals: { ${3:item}: @${3} } %>$0"
    ]
  },
  "Turbo stream append": {
    "prefix": "turboappend",
    "description": "turbo_stream append",
    "body": [
      "<%= turbo_stream.append '${1:dom_id}', partial: '${2:partial}', locals: { ${3:item}: @${3} } %>$0"
    ]
  },
  "Turbo stream remove": {
    "prefix": "turboremove",
    "description": "turbo_stream remove dom_id",
    "body": ["<%= turbo_stream.remove ${1:@resource} %>$0"]
  },
  "Stimulus data-controller": {
    "prefix": "datactrl",
    "description": "data-controller attribute",
    "body": ["data-controller=\"${1:name}\"$0"]
  },
  "Stimulus action": {
    "prefix": "dataaction",
    "description": "data-action attribute",
    "body": ["data-action=\"${1:click}->${2:controller}#${3:method}\"$0"]
  },
  "Stimulus target": {
    "prefix": "datatarget",
    "description": "data-target attribute",
    "body": ["data-${1:controller}-target=\"${2:name}\"$0"]
  },
  "Stimulus value": {
    "prefix": "datavalue",
    "description": "data-value attribute",
    "body": ["data-${1:controller}-${2:url}-value=\"${3:value}\"$0"]
  },
  "Stimulus wrapper div": {
    "prefix": "stimwrap",
    "description": "div w/ controller + targets",
    "body": [
      "<div data-controller=\"${1:name}\">",
      "\t<input data-${1}-target=\"${2:input}\">",
      "\t<button data-action=\"click->${1}#${3:submit}\">${4:Go}</button>",
      "</div>$0"
    ]
  },
  "ActiveAdmin form input": {
    "prefix": "aainput",
    "description": "AA f.input (in form do)",
    "body": ["f.input :${1:attr}${2:, as: :${3:select}, collection: ${4:[]}}$0"]
  },
  "ERB cache block": {
    "prefix": "cacheblock",
    "description": "fragment cache block",
    "body": ["<% cache ${1:@item} do %>", "\t$0", "<% end %>"]
  },
  "ERB cache collection": {
    "prefix": "cachecollection",
    "description": "render partial cached: true",
    "body": ["<%= render partial: '${1:item}', collection: ${2:@items}, cached: true %>$0"]
  },
  "ERB Pundit policy if": {
    "prefix": "policyif",
    "description": "policy().action? guard",
    "body": ["<% if policy(${1:@item}).${2:edit?} %>", "\t$0", "<% end %>"]
  },
  "ERB t lazy": {
    "prefix": "tlazyerb",
    "description": "<%= t('.key') %>",
    "body": ["<%= t('.${1:key}') %>$0"]
  },
  "ERB errors_for": {
    "prefix": "errorsfor",
    "description": "errors full_messages list",
    "body": [
      "<% if ${1:@record}.errors.any? %>",
      "\t<ul>",
      "\t\t<% ${1}.errors.full_messages.each do |m| %>",
      "\t\t\t<li><%= m %></li>",
      "\t\t<% end %>",
      "\t</ul>",
      "<% end %>$0"
    ]
  },
  "ERB time_ago_in_words": {
    "prefix": "timeago",
    "description": "time_ago_in_words",
    "body": ["<%= time_ago_in_words(${1:@item}.created_at) %> ago$0"]
  },
  "ERB link_to_if": {
    "prefix": "linktoif",
    "description": "link_to_if",
    "body": ["<%= link_to_if ${1:condition}, '${2:Label}', ${3:path} %>$0"]
  },
  "ERB safe_join": {
    "prefix": "safejoin",
    "description": "safe_join",
    "body": ["<%= safe_join(${1:items}, '${2:, }') %>$0"]
  },
  "ERB simple_format": {
    "prefix": "simpleformat",
    "description": "simple_format",
    "body": ["<%= simple_format(${1:text}) %>$0"]
  },
  "ERB number_to_currency": {
    "prefix": "numbercurrency",
    "description": "number_to_currency",
    "body": ["<%= number_to_currency(${1:value}) %>$0"]
  },
  "ERB Ransack search form": {
    "prefix": "ransackform",
    "description": "search_form_for @q",
    "body": [
      "<%= search_form_for @q do |f| %>",
      "\t<%= f.label :${1:attr}_cont %>",
      "\t<%= f.search_field :${1}_cont %>",
      "\t<%= f.submit %>",
      "<% end %>$0"
    ]
  },
  "ERB pagy nav": {
    "prefix": "pagynav",
    "description": "pagy_nav helper",
    "body": ["<%== pagy_nav(@pagy) %>$0"]
  },
  "ERB kaminari paginate": {
    "prefix": "kaminarinav",
    "description": "<%= paginate %>",
    "body": ["<%= paginate ${1:@records} %>$0"]
  },
  "ERB ViewComponent render": {
    "prefix": "vcrendererb",
    "description": "<%= render XComponent.new %>",
    "body": ["<%= render(${1:Name}Component.new(${2:args})) %>$0"]
  },
  "Form fields_for": {
    "prefix": "fieldset",
    "description": "f.fields_for nested",
    "body": [
      "<%= f.fields_for :${1:assoc} do |g| %>",
      "\t$0",
      "<% end %>"
    ]
  },
  "Form label": {
    "prefix": "flabel",
    "description": "f.label",
    "body": ["<%= f.label :${1:attr} %>$0"]
  },
  "Form text_field": {
    "prefix": "ftext",
    "description": "f.text_field",
    "body": ["<%= f.text_field :${1:attr} %>$0"]
  },
  "Form text_area": {
    "prefix": "ftextarea",
    "description": "f.text_area",
    "body": ["<%= f.text_area :${1:attr}${2:, rows: 4} %>$0"]
  },
  "Form email_field": {
    "prefix": "femail",
    "description": "f.email_field",
    "body": ["<%= f.email_field :${1:email} %>$0"]
  },
  "Form password_field": {
    "prefix": "fpassword",
    "description": "f.password_field",
    "body": ["<%= f.password_field :${1:password} %>$0"]
  },
  "Form number_field": {
    "prefix": "fnumber",
    "description": "f.number_field",
    "body": ["<%= f.number_field :${1:attr}${2:, step: 1} %>$0"]
  },
  "Form date_field": {
    "prefix": "fdate",
    "description": "f.date_field",
    "body": ["<%= f.date_field :${1:attr} %>$0"]
  },
  "Form check_box": {
    "prefix": "fcheck",
    "description": "f.check_box",
    "body": ["<%= f.check_box :${1:attr} %>$0"]
  },
  "Form radio_button": {
    "prefix": "fradio",
    "description": "f.radio_button",
    "body": ["<%= f.radio_button :${1:attr}, ${2:value} %>$0"]
  },
  "Form hidden_field": {
    "prefix": "fhidden",
    "description": "f.hidden_field",
    "body": ["<%= f.hidden_field :${1:attr}${2:, value: ${3:val}} %>$0"]
  },
  "Form file_field": {
    "prefix": "ffile",
    "description": "f.file_field",
    "body": ["<%= f.file_field :${1:attr}${2:, multiple: true} %>$0"]
  },
  "Form select": {
    "prefix": "fselect",
    "description": "f.select w/ options_for_select",
    "body": [
      "<%= f.select :${1:attr}, options_for_select(${2:[['Label', 'value']]}, ${3:@record}.${1}) %>$0"
    ]
  },
  "Form collection_select": {
    "prefix": "fcollection",
    "description": "f.collection_select",
    "body": [
      "<%= f.collection_select :${1:assoc_id}, ${2:Scope.all}, :${3:id}, :${4:name}${5:, include_blank: true} %>$0"
    ]
  },
  "select_tag": {
    "prefix": "selecttag",
    "description": "select_tag",
    "body": [
      "<%= select_tag :${1:name}, options_for_select(${2:[['Label', 'value']]}) %>$0"
    ]
  },
  "options_for_select": {
    "prefix": "optsfor",
    "description": "options_for_select",
    "body": ["options_for_select(${1:[['Label', 'value']]}${2:, ${3:selected}})$0"]
  },
  "options_from_collection_for_select": {
    "prefix": "optsfromcoll",
    "description": "options_from_collection_for_select",
    "body": [
      "options_from_collection_for_select(${1:scope}, :${2:id}, :${3:name}${4:, ${5:selected}})$0"
    ]
  },
  "mail_to": {
    "prefix": "mailto",
    "description": "mail_to helper",
    "body": ["<%= mail_to ${1:@user}.email${2:, ${1}.name} %>$0"]
  },
  "number_with_delimiter": {
    "prefix": "numberwith",
    "description": "number_with_delimiter",
    "body": ["<%= number_with_delimiter(${1:value}) %>$0"]
  },
  "number_to_percentage": {
    "prefix": "numberpct",
    "description": "number_to_percentage",
    "body": ["<%= number_to_percentage(${1:value}, precision: ${2:2}) %>$0"]
  },
  "truncate": {
    "prefix": "truncate",
    "description": "truncate helper",
    "body": ["<%= truncate(${1:text}, length: ${2:30}) %>$0"]
  },
  "pluralize": {
    "prefix": "pluralize",
    "description": "pluralize helper",
    "body": ["<%= pluralize(${1:count}, '${2:word}') %>$0"]
  },
  "dom_id": {
    "prefix": "domid",
    "description": "dom_id helper",
    "body": ["<%= dom_id(${1:@record}${2:, :${3:prefix}}) %>$0"]
  },
  "dom_class": {
    "prefix": "domclass",
    "description": "dom_class helper",
    "body": ["<%= dom_class(${1:@record}${2:, :${3:prefix}}) %>$0"]
  },
  "time_tag": {
    "prefix": "timetag",
    "description": "time_tag",
    "body": ["<%= time_tag ${1:@record}.created_at${2:, l(${1}.created_at)} %>$0"]
  },
  "javascript_include_tag": {
    "prefix": "jstag",
    "description": "javascript_include_tag",
    "body": ["<%= javascript_include_tag '${1:application}'${2:, defer: true} %>$0"]
  },
  "stylesheet_link_tag": {
    "prefix": "csstag",
    "description": "stylesheet_link_tag",
    "body": ["<%= stylesheet_link_tag '${1:application}'${2:, media: 'all'} %>$0"]
  },
  "javascript_importmap_tags": {
    "prefix": "jsimportmap",
    "description": "javascript_importmap_tags",
    "body": ["<%= javascript_importmap_tags %>$0"]
  },
  "HTML5 layout": {
    "prefix": "layouthtml",
    "description": "full Rails HTML5 layout",
    "body": [
      "<!DOCTYPE html>",
      "<html>",
      "\t<head>",
      "\t\t<title><%= content_for?(:title) ? yield(:title) : '${1:App}' %></title>",
      "\t\t<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">",
      "\t\t<%= csrf_meta_tags %>",
      "\t\t<%= csp_meta_tag %>",
      "\t\t<%= stylesheet_link_tag 'application', media: 'all' %>",
      "\t\t<%= javascript_importmap_tags %>",
      "\t</head>",
      "\t<body>",
      "\t\t<%= yield %>$0",
      "\t</body>",
      "</html>"
    ]
  },
  "meta tag": {
    "prefix": "metatag",
    "description": "tag.meta",
    "body": ["<%= tag.meta name: '${1:name}', content: '${2:content}' %>$0"]
  },
  "head title": {
    "prefix": "headtitle",
    "description": "title fallback",
    "body": [
      "<title><%= content_for?(:title) ? yield(:title) : '${1:App}' %></title>$0"
    ]
  },
  "simple_form_for": {
    "prefix": "simpleform",
    "description": "simple_form_for",
    "body": [
      "<%= simple_form_for ${1:@resource} do |f| %>",
      "\t$0",
      "\t<%= f.button :submit %>",
      "<% end %>"
    ]
  },
  "simple_form input": {
    "prefix": "sfinput",
    "description": "simple_form f.input",
    "body": ["<%= f.input :${1:attr}${2:, as: :${3:string}} %>$0"]
  },
  "simple_form button": {
    "prefix": "sfbutton",
    "description": "simple_form f.button",
    "body": ["<%= f.button :submit${1:, '${2:Save}'} %>$0"]
  },
  "link_to block": {
    "prefix": "linkblock",
    "description": "link_to block form",
    "body": [
      "<%= link_to ${1:path} do %>",
      "\t$0",
      "<% end %>"
    ]
  },
  "button_to block": {
    "prefix": "buttontoblock",
    "description": "button_to block form",
    "body": [
      "<%= button_to ${1:path}, method: :${2:post} do %>",
      "\t$0",
      "<% end %>"
    ]
  },
  "current_page?": {
    "prefix": "currentpage",
    "description": "current_page? guard",
    "body": [
      "<% if current_page?(${1:path}) %>",
      "\t$0",
      "<% end %>"
    ]
  },
  "concat helper": {
    "prefix": "concat",
    "description": "concat output",
    "body": ["<% concat(${1:value}) %>$0"]
  },
  "raw html": {
    "prefix": "rawhtml",
    "description": "raw(html)",
    "body": ["<%= raw(${1:html}) %>$0"]
  },
  "html_safe": {
    "prefix": "htmlsafe",
    "description": ".html_safe",
    "body": ["<%= ${1:text}.html_safe %>$0"]
  }
}
