{
  "PHP public function": {
    "prefix": "puf",
    "description": "public method with return type",
    "body": [
      "public function ${1:name}(${2}): ${3:void} {",
      "\t$0",
      "}"
    ]
  },
  "PHP private function": {
    "prefix": "prf",
    "description": "private method",
    "body": [
      "private function ${1:name}(${2}): ${3:void} {",
      "\t$0",
      "}"
    ]
  },
  "PHP public static function": {
    "prefix": "psf",
    "description": "public static method",
    "body": [
      "public static function ${1:name}(${2}): ${3:void} {",
      "\t$0",
      "}"
    ]
  },
  "PHP arrow fn": {
    "prefix": "afn",
    "description": "arrow fn",
    "body": ["fn(${1:\\$x}) => ${0}"]
  },
  "PHP arrow fn short": {
    "prefix": "fn",
    "description": "arrow fn (short alias)",
    "body": ["fn(${1:\\$x}) => ${0}"]
