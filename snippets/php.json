  "GAF Repo try-fetch": {
    "prefix": "fl-repo-fetch",
    "description": "Repository fetch fn w/ try/catch",
    "body": [
      "/**",
      " * @throws DBException",
      " */",
      "public function ${1:get}(${2:int \\$id}): ?DTO {",
      "\t\\$sql = <<<'SQL'",
      "\t\tSELECT *",
      "\t\tFROM ${3:table}",
      "\t\tWHERE id = %d",
      "\t\tSQL;",
      "\ttry {",
      "\t\treturn MySql::fetchOne(",
      "\t\t\tsql: \\$sql,",
      "\t\t\tdtoClassName: DTO::class,",
      "\t\t\tbinds: [\\$id],",
      "\t\t);",
      "\t} catch (DBQueryException \\$e) {",
      "\t\treturn null;",
      "\t} catch (Exception \\$e) {",
      "\t\tLogger::error('failed to fetch from ${3}', ['exception' => \\$e]);",
      "\t\tthrow \\$e;",
      "\t}",
      "}$0"
    ]
  },
