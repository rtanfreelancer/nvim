  "GAF Controller": {
    "prefix": "fl-controller",
    "description": "GAF Phoenix controller skeleton",
    "body": [
      "<?php",
      "",
      "namespace Freelancer\\\\Phoenix\\\\Controller\\\\Module;",
      "",
      "use Freelancer\\\\GAF\\\\Core\\\\Exception\\\\Response\\\\MethodNotAllowedException;",
      "use Symfony\\\\Component\\\\HttpFoundation\\\\Request;",
      "",
      "/**",
      " * ${1:Description}.",
      " *",
      " * @api",
      " */",
      "final class Controller {",
      "\tpublic function __construct(",
      "\t\tprivate Handler \\$handler = new Handler(),",
      "\t) {}",
      "",
      "\t/**",
      "\t * ${2:Method description}.",
      "\t *",
      "\t * @throws MethodNotAllowedException",
      "\t */",
      "\tpublic function ${3:action}(Request \\$request): array {",
      "\t\tif (\\$request->getMethod() !== '${4:GET}') {",
      "\t\t\tthrow new MethodNotAllowedException(",
      "\t\t\t\t\"Method {\\$request->getMethod()} is not allowed.\"",
      "\t\t\t);",
      "\t\t}",
      "",
      "\t\t$0",
      "",
      "\t\treturn [];",
      "\t}",
      "}"
    ]
  },
  "GAF Handler": {
    "prefix": "fl-handler",
    "description": "GAF Phoenix handler with optional injected deps",
    "body": [
      "<?php",
      "",
      "namespace Freelancer\\\\Phoenix\\\\Handler\\\\Module;",
      "",
      "use Freelancer\\\\GAF\\\\Core\\\\Log\\\\Logger;",
      "",
      "/**",
      " * ${1:Description}.",
      " */",
      "final class Handler {",
      "\t/** @readonly */",
      "\tprivate Repository \\$repository;",
      "",
      "\tpublic function __construct(",
      "\t\t?Repository \\$repository = null,",
      "\t) {",
      "\t\t\\$this->repository = \\$repository ?? new Repository();",
      "\t}",
      "",
      "\tpublic function ${2:method}(${3}): ${4:void} {",
      "\t\t$0",
      "\t}",
      "}"
    ]
  },
