  "GAF Consumer": {
    "prefix": "fl-consumer",
    "description": "RabbitMQ consumer (legacy script style)",
    "body": [
      "<?php",
      "",
      "use Freelancer\\\\GAF\\\\Core\\\\Log\\\\Logger;",
      "use PhpAmqpLib\\\\Message\\\\AMQPMessage;",
      "",
      "require_once __DIR__.'/../public/lib/common.php';",
      "",
      "ini_set('memory_limit', '${1:1000M}');",
      "",
      "\\$callback = static function (AMQPMessage \\$msg): void {",
      "\t\\$channel = \\$msg->get('channel');",
      "\t\\$delivery_tag = \\$msg->get('delivery_tag');",
      "\ttry {",
      "\t\t\\$body = json_decode(\\$msg->body);",
      "\t\t$0",
      "\t\t\\$channel->basic_ack(\\$delivery_tag);",
      "\t} catch (DBConnectException \\$e) {",
      "\t\tLogger::warning(\\$e);",
      "\t\t\\$channel->basic_reject(\\$delivery_tag, true);",
      "\t} catch (RabbitException \\$e) {",
      "\t\tLogger::info(\\$e);",
      "\t\t\\$channel->basic_reject(\\$delivery_tag, \\$e->getRequeue());",
      "\t} catch (Exception \\$e) {",
      "\t\tLogger::info(\\$e);",
      "\t\t\\$channel->basic_reject(\\$delivery_tag, true);",
      "\t\texit;",
      "\t}",
      "};"
    ]
  },
