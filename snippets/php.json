  "PHP match": {
    "prefix": "match",
    "description": "match expression",
    "body": [
      "match (${1:\\$value}) {",
      "\t${2:'a'} => ${3:expr},",
      "\tdefault => ${4:expr},",
      "};$0"
    ]
  },
  "PHP try logger": {
    "prefix": "tryl",
    "description": "try/catch with logger rethrow",
    "body": [
      "try {",
      "\t$1",
      "} catch (${2:Exception} \\$e) {",
      "\tLogger::error('${3:msg}', ['exception' => \\$e]);",
      "\tthrow \\$e;",
      "}$0"
    ]
  },
